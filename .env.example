APP_HOST=0.0.0.0
APP_PORT=18000
STORAGE_DB_PATH=data/trade.db
EXCHANGE_NAME=binance

# paper or live
TRADE_MODE=paper

# Safety guard: must be true to allow live order submission
LIVE_CONFIRM=false

# use true if you use Binance spot testnet keys/endpoint support in ccxt
USE_BINANCE_TESTNET=false

BINANCE_API_KEY=
BINANCE_API_SECRET=

DEFAULT_SYMBOL=BTC/USDT
TIMEFRAME=1m
POLL_SECONDS=20

STRATEGY_NAME=ema_cross
EMA_FAST=9
EMA_SLOW=21
BOLL_WINDOW=20
BOLL_STD_MULT=2.0
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
GRID_PCT=0.01

RISK_MAX_POSITION_USDT=100
RISK_MAX_DAILY_LOSS_USDT=50

FEISHU_ALERT_ENABLED=false
FEISHU_WEBHOOK_URL=
